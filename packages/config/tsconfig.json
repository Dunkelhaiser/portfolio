{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "strict": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "paths": {
            "@/*": ["./src/*"]
        },
        "jsx": "react-jsx",
        "jsxImportSource": "react"
    }
}
