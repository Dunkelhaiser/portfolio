---
import { Badge } from "@repo/ui/Badge";
import { Calendar, MapPin } from "@repo/ui/icons";
import type { CloudinaryImage } from "@/lib/types";
import { unixToDate, unixToISODate } from "@/lib/utils";

interface Props {
    images: CloudinaryImage[];
}

const { images } = Astro.props;
---

<div class="grid gap-4 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    {images.map((img) => {
        const title = img.context?.caption;
        const description = img.context?.alt;
        const location = img.metadata?.location || null;
        
        const date = unixToDate(img.metadata?.takenAt);
        const isoDate = unixToISODate(img.metadata?.takenAt);

        return (
            <div class="relative group overflow-hidden rounded-lg border border-border">
                <img 
                    src={img.src} 
                    alt={description} 
                    loading="lazy" 
                    class="w-full h-auto block object-cover" 
                />

                {img.tags && img.tags.length > 0 && (
                    <div class="absolute top-2.5 right-2.5 flex flex-wrap justify-end gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10">
                        {img.tags.map((tag) => (
                            <Badge variant="blur">{tag}</Badge>
                        ))}
                    </div>
                )}

                <div class="absolute bottom-0 left-0 right-0 p-4 pt-3 bg-black/50 backdrop-blur-md text-white translate-y-full group-hover:translate-y-0 transition-transform duration-300 z-10">
                    {title && (
                        <h3 class="font-semibold drop-shadow-sm truncate">
                            {title}
                        </h3>
                    )}
                    
                    <div class="flex items-center justify-between text-sm mt-1 opacity-90 drop-shadow-sm">
                        {location ? <span class="flex gap-1 items-center font-mono"><MapPin className="size-4" /> {location}</span> : <span></span>}
                        {date && <time datetime={isoDate} class="flex gap-1 tabular-nums font-mono"><Calendar className="size-4" /> {date}</time>}
                    </div>
                </div>

                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            </div>
        );
    })}
</div>
