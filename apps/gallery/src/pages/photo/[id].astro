---
/** biome-ignore-all lint/style/useNamingConvention: cloudinary convention */
import { getEntry } from "astro:content";
import { ChevronRight } from "@repo/ui/icons";
import { v2 as cloudinary } from "cloudinary";
import { ImageArea } from "@/components/Image/ImageArea";
import { ImageMetadata } from "@/components/Image/ImageMetadata";
import Layout from "@/layouts/Layout.astro";
import { getSignedUrl, HIGH_RES_WIDTH } from "@/lib/cloudinary";
import { flattenImageMetadata } from "@/lib/metadata";
import type { CloudinaryResourceById } from "@/lib/types";

const { id } = Astro.params;
const decodedId = decodeURIComponent(id as string);

const url = getSignedUrl(decodedId, HIGH_RES_WIDTH);

const resource: CloudinaryResourceById | null = await cloudinary.api.resource(decodedId, {
    type: "authenticated",
    tags: true,
    context: true,
    metadata: true,
});

if (!resource) {
    return Astro.redirect("/");
}

const metadata = flattenImageMetadata(resource);

const groupId = resource.context?.custom?.group;
let groupTitle: string | null = null;
if (groupId) {
    const groupEntry = await getEntry("groups", groupId);
    groupTitle = groupEntry?.data.title ?? groupId;
    metadata.groupTitle = groupTitle;
}

export const prerender = false;
---

<Layout>
    <div class="mb-6 flex items-center gap-1.5 text-sm text-muted-foreground">
        <a href="/" class="hover:text-foreground transition-colors">Gallery</a>
        {groupId && groupTitle && (
            <>
                <ChevronRight className="size-4" />
                <a href={`/group/${groupId}`} class="hover:text-foreground transition-colors">{groupTitle}</a>
            </>
        )}
        <ChevronRight className="size-4 shrink-0" />
        <span class="text-foreground font-medium truncate max-w-[200px] md:max-w-xs">{metadata.title || 'Photo'}</span>
    </div>

    <div class="flex flex-col lg:flex-row">
        <ImageArea client:load src={url} alt={metadata.description} className="lg:px-4 lg:pb-0 pb-4" />
        <ImageMetadata metadata={metadata} className="lg:p-8 lg:pr-0" />
    </div>
</Layout>