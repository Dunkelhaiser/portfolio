---
/** biome-ignore-all lint/style/useNamingConvention: cloudinary convention */
import { getEntry } from "astro:content";
import { buttonVariants } from "@repo/ui/Button";
import { Calendar, ChevronLeft, MapPin } from "@repo/ui/icons";
import EmptyState from "@/components/Sections/Gallery/EmptyState.astro";
import { Filters } from "@/components/Sections/Gallery/Filters";
import ImagesList from "@/components/Sections/Gallery/Images/ImagesList.astro";
import Layout from "@/layouts/Layout.astro";
import { getSignedUrl, HIGH_RES_WIDTH, PREVIEW_WIDTH, searchImages } from "@/lib/cloudinary";
import { calculateMasonryPages } from "@/lib/masonry";
import type { CloudinaryImage, CloudinaryResource } from "@/lib/types";
import { formatCameraName, getDaypart, getSeason, unixToDate } from "@/lib/utils";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/?view=groups");

const groupEntry = await getEntry("groups", slug);
const groupName = groupEntry?.data.title ?? slug;
const groupDescription = groupEntry?.data.description;

// @ts-expect-error
const env = Astro.locals.runtime.env;

const pageParam = Astro.url.searchParams.get("page") ?? "1";
const tagsParam = Astro.url.searchParams.get("tags") ?? "";
const selectedTagsArray = tagsParam ? tagsParam.split(",") : [];
const camerasParam = Astro.url.searchParams.get("cameras") ?? "";
const selectedCamerasArray = camerasParam ? camerasParam.split(",") : [];
const locationsParam = Astro.url.searchParams.get("locations") ?? "";
const selectedLocationsArray = locationsParam ? locationsParam.split(",") : [];
const daypartsParam = Astro.url.searchParams.get("dayparts") ?? "";
const selectedDaypartsArray = daypartsParam ? daypartsParam.split(",") : [];
const seasonsParam = Astro.url.searchParams.get("seasons") ?? "";
const selectedSeasonsArray = seasonsParam ? seasonsParam.split(",") : [];
const currentPage = Number.parseInt(pageParam, 10) ?? 1;

const queryTags = tagsParam ? `tags=${tagsParam}` : "";
const queryCameras = camerasParam ? `cameras=${camerasParam}` : "";
const queryLocations = locationsParam ? `locations=${locationsParam}` : "";
const queryDayparts = daypartsParam ? `dayparts=${daypartsParam}` : "";
const querySeasons = seasonsParam ? `seasons=${seasonsParam}` : "";
const queryParts = [queryTags, queryCameras, queryLocations, queryDayparts, querySeasons].filter(Boolean);
const queryStr = queryParts.length > 0 ? `&${queryParts.join("&")}` : "";

const searchExpression = `folder:gallery AND context.group=${slug}`;
const maxResults = 500;

const results = await searchImages(
    searchExpression,
    maxResults,
    env.CLOUDINARY_CLOUD_NAME,
    env.CLOUDINARY_API_KEY,
    env.CLOUDINARY_API_SECRET,
    "asc"
);

const allImages: Omit<CloudinaryImage, "src">[] = results.resources.map((img: CloudinaryResource) => ({
    id: img.public_id,
    tags: img.tags || [],
    context: img.context || {},
    metadata: img.metadata || {},
    width: img.width,
    height: img.height,
}));

const availableTagsSet = new Set<string>();
const availableCamerasSet = new Set<string>();
const availableLocationsSet = new Set<string>();
const availableDaypartsSet = new Set<string>();
const availableSeasonsSet = new Set<string>();

for (const img of allImages) {
    for (const tag of img.tags) {
        availableTagsSet.add(tag);
    }
    if (img.metadata?.camera) {
        availableCamerasSet.add(img.metadata.camera);
    }
    if (img.metadata?.location) {
        availableLocationsSet.add(img.metadata.location);
    }
    const daypart = getDaypart(img.metadata?.takenAt);
    if (daypart) {
        availableDaypartsSet.add(daypart);
    }
    const season = getSeason(img.metadata?.takenAt);
    if (season) {
        availableSeasonsSet.add(season);
    }
}

const availableTags = Array.from(availableTagsSet)
    .sort()
    .map((t) => ({ label: t, value: t }));
const selectedTagsOptions = selectedTagsArray.map((t) => ({ label: t, value: t }));

const availableCameras = Array.from(availableCamerasSet)
    .sort()
    .map((c) => ({ label: formatCameraName(c), value: c }));
const selectedCamerasOptions = selectedCamerasArray.map((c) => ({ label: formatCameraName(c), value: c }));

const availableLocations = Array.from(availableLocationsSet)
    .sort()
    .map((l) => ({ label: l, value: l }));
const selectedLocationsOptions = selectedLocationsArray.map((l) => ({ label: l, value: l }));

const DAYPART_ORDER = ["Dawn", "Morning", "Afternoon", "Twilight", "Evening", "Night"];
const availableDayparts = Array.from(availableDaypartsSet)
    .sort((a, b) => DAYPART_ORDER.indexOf(a) - DAYPART_ORDER.indexOf(b))
    .map((d) => ({ label: d, value: d }));
const selectedDaypartsOptions = selectedDaypartsArray.map((d) => ({ label: d, value: d }));

const SEASON_ORDER = ["Winter", "Spring", "Summer", "Autumn"];
const availableSeasons = Array.from(availableSeasonsSet)
    .sort((a, b) => SEASON_ORDER.indexOf(a) - SEASON_ORDER.indexOf(b))
    .map((s) => ({ label: s, value: s }));
const selectedSeasonsOptions = selectedSeasonsArray.map((s) => ({ label: s, value: s }));

const uniqueDates = Array.from(
    new Set(
        allImages
            .map((img) => img.metadata?.takenAt)
            .filter((val): val is number => typeof val === "number")
            .sort((a, b) => a - b)
            .map((timestamp) => unixToDate(timestamp))
    )
);
const uniqueLocations = Array.from(availableLocationsSet).sort();

if (allImages.length === 0) {
    return Astro.redirect("/?view=groups");
}

const filteredImages = allImages.filter((img) => {
    const matchesTags = selectedTagsArray.length === 0 || selectedTagsArray.every((tag) => img.tags.includes(tag));
    const matchesCameras =
        selectedCamerasArray.length === 0 || selectedCamerasArray.includes(img.metadata?.camera ?? "");
    const matchesLocations =
        selectedLocationsArray.length === 0 || selectedLocationsArray.includes(img.metadata?.location ?? "");
    const matchesDayparts =
        selectedDaypartsArray.length === 0 || selectedDaypartsArray.includes(getDaypart(img.metadata?.takenAt) ?? "");
    const matchesSeasons =
        selectedSeasonsArray.length === 0 || selectedSeasonsArray.includes(getSeason(img.metadata?.takenAt) ?? "");
    return matchesTags && matchesCameras && matchesLocations && matchesDayparts && matchesSeasons;
});

const pages = calculateMasonryPages(filteredImages, {
    targetPerPage: 12,
    minPerPage: 9,
    maxPerPage: 15,
});

const totalPages = pages.length;

if (currentPage < 1) return Astro.redirect(`/group/${slug}?page=1${queryStr}`);
if (currentPage > totalPages && totalPages > 0) return Astro.redirect(`/group/${slug}?page=${totalPages}${queryStr}`);

const paginatedImages = totalPages > 0 && pages[currentPage - 1] ? pages[currentPage - 1] : [];
const paginationNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);

const secureImages: CloudinaryImage[] = await Promise.all(
    paginatedImages.map(async (img) => ({
        ...img,
        previewSrc: await getSignedUrl(img.id, PREVIEW_WIDTH, env.CLOUDINARY_CLOUD_NAME, env.CLOUDINARY_API_SECRET),
        highResSrc: await getSignedUrl(img.id, HIGH_RES_WIDTH, env.CLOUDINARY_CLOUD_NAME, env.CLOUDINARY_API_SECRET),
        groupTitle: groupName,
    }))
);
---

<Layout>
    <div class="mb-8">
        <a href="/?view=groups" class={buttonVariants({ variant: "ghost", className: "mb-6 -ml-4 text-muted-foreground" })}>
            <ChevronLeft className="mr-2 size-4" />
            Back to Groups
        </a>
        <h1 class="text-3xl font-bold">{groupName}</h1>
        
        {(uniqueDates.length > 0 || uniqueLocations.length > 0) && (
            <div class="mt-4 flex flex-wrap items-center gap-4 text-muted-foreground">
                {uniqueDates.length > 0 && (
                    <span class="flex gap-1.5 items-center font-mono text-sm tabular-nums">
                        <Calendar className="size-4 shrink-0" /> {uniqueDates.join("; ")}
                    </span>
                )}
                {uniqueLocations.length > 0 && (
                    <span class="flex gap-1.5 items-center font-mono text-sm">
                        <MapPin className="size-4 shrink-0" /> {uniqueLocations.join("; ")}
                    </span>
                )}
            </div>
        )}

        {groupDescription && <p class="text-muted-foreground mt-2 max-w-prose">{groupDescription}</p>}
        
        <div class="mt-6">
            <Filters 
                client:load 
                availableTags={availableTags} 
                selectedTags={selectedTagsOptions} 
                availableCameras={availableCameras}
                selectedCameras={selectedCamerasOptions}
                availableLocations={availableLocations}
                selectedLocations={selectedLocationsOptions}
                availableDayparts={availableDayparts}
                selectedDayparts={selectedDaypartsOptions}
                availableSeasons={availableSeasons}
                selectedSeasons={selectedSeasonsOptions}
            />
        </div>
    </div>

    {secureImages.length > 0 ? (
        <ImagesList 
            images={secureImages} 
            currentPage={currentPage} 
            totalPages={totalPages} 
            paginationNumbers={paginationNumbers} 
            baseUrl={`/group/${slug}?${queryStr ? queryStr.slice(1) + '&' : ''}page=`} 
        />
    ) : (
        <EmptyState itemType="photos" clearUrl={`/group/${slug}`} />
    )}
</Layout>
