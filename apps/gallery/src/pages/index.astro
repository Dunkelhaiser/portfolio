---
/** biome-ignore-all lint/style/useNamingConvention: cloudinary convention */
import { getCollection } from "astro:content";
import { v2 as cloudinary } from "cloudinary";
import { Filters } from "@/components/Sections/Gallery/Filters";
import GroupsList from "@/components/Sections/Gallery/Groups/GroupsList.astro";
import ImagesList from "@/components/Sections/Gallery/Images/ImagesList.astro";
import { ViewTabs } from "@/components/Sections/Gallery/ViewTabs";
import Layout from "@/layouts/Layout.astro";
import { getSignedUrl, HIGH_RES_WIDTH, PREVIEW_WIDTH } from "@/lib/cloudinary";
import { calculateMasonryPages } from "@/lib/masonry";
import type { CloudinaryImage, CloudinaryResource } from "@/lib/types";

cloudinary.config({
    cloud_name: import.meta.env.CLOUDINARY_CLOUD_NAME,
    api_key: import.meta.env.CLOUDINARY_API_KEY,
    api_secret: import.meta.env.CLOUDINARY_API_SECRET,
});

const viewParam = Astro.url.searchParams.get("view") ?? "flat";
const pageParam = Astro.url.searchParams.get("page") ?? "1";
const tagsParam = Astro.url.searchParams.get("tags") ?? "";
const selectedTagsArray = tagsParam ? tagsParam.split(",") : [];
const currentPage = Number.parseInt(pageParam, 10) ?? 1;

const queryStr = tagsParam ? `&tags=${tagsParam}` : "";

const isFlat = viewParam === "flat";
const flatPage = isFlat ? currentPage : 1;
const groupPage = isFlat ? 1 : currentPage;

const searchExpression = "folder:gallery";
const maxResults = 500;

const results = await cloudinary.search
    .expression(searchExpression)
    .with_field("tags")
    .with_field("context")
    .with_field("metadata")
    .sort_by("metadata.takenAt", "desc")
    .max_results(maxResults)
    .execute();

const allImages: Omit<CloudinaryImage, "src">[] = results.resources.map((img: CloudinaryResource) => ({
    id: img.public_id,
    tags: img.tags || [],
    context: img.context || {},
    metadata: img.metadata || {},
    width: img.width,
    height: img.height,
}));

const availableTagsSet = new Set<string>();
for (const img of allImages) {
    for (const tag of img.tags) {
        availableTagsSet.add(tag);
    }
}
const availableTags = Array.from(availableTagsSet)
    .sort()
    .map((t) => ({ label: t, value: t }));
const selectedTagsOptions = selectedTagsArray.map((t) => ({ label: t, value: t }));

const filteredImages =
    selectedTagsArray.length > 0
        ? allImages.filter((img) => selectedTagsArray.every((tag) => img.tags.includes(tag)))
        : allImages;

const pages = calculateMasonryPages(filteredImages, {
    targetPerPage: 12,
    minPerPage: 9,
    maxPerPage: 15,
});

const totalFlatPages = pages.length;
if (isFlat && currentPage < 1) return Astro.redirect(`/?page=1&view=flat${queryStr}`);
if (isFlat && currentPage > totalFlatPages && totalFlatPages > 0)
    return Astro.redirect(`/?page=${totalFlatPages}&view=flat${queryStr}`);

const paginatedImages = totalFlatPages > 0 && pages[flatPage - 1] ? pages[flatPage - 1] : [];
const flatPaginationNumbers = Array.from({ length: totalFlatPages }, (_, i) => i + 1);

const contentGroups = await getCollection("groups");
const groupTitleMap = new Map<string, string>();
for (const cg of contentGroups) {
    const groupId = cg.id.split(".md")[0];
    groupTitleMap.set(groupId, cg.data.title);
}

const secureImages: CloudinaryImage[] = paginatedImages.map((img) => ({
    ...img,
    previewSrc: getSignedUrl(img.id, PREVIEW_WIDTH),
    highResSrc: getSignedUrl(img.id, HIGH_RES_WIDTH),
    groupTitle: img.context?.group ? (groupTitleMap.get(img.context.group) ?? img.context.group) : undefined,
}));

const groupMap = new Map<string, { previewImg: (typeof allImages)[0]; tags: Set<string> }>();
for (const img of allImages) {
    if (img.context?.group) {
        const groupId = img.context.group;
        const groupData = groupMap.get(groupId);
        if (groupData) {
            groupData.previewImg = img;
            for (const tag of img.tags || []) {
                groupData.tags.add(tag);
            }
        } else {
            groupMap.set(groupId, { previewImg: img, tags: new Set(img.tags || []) });
        }
    }
}

const allGroupsList = Array.from(groupMap.entries()).map(([groupId, { previewImg, tags }]) => ({
    id: groupId,
    previewSrc: getSignedUrl(previewImg.id, PREVIEW_WIDTH),
    tags: Array.from(tags).sort(),
}));

const filteredGroupsList =
    selectedTagsArray.length > 0
        ? allGroupsList.filter((g) => selectedTagsArray.every((tag) => g.tags.includes(tag)))
        : allGroupsList;

const groupsWithData = filteredGroupsList.map((group) => {
    const contentGroup = contentGroups.find((c) => c.id.split(".md")[0] === group.id);
    const data = contentGroup?.data;

    let previewSrc = group.previewSrc;
    if (data?.previewImageId) {
        previewSrc = getSignedUrl(data.previewImageId, PREVIEW_WIDTH);
    }

    return { ...group, data, previewSrc };
});

const groupsPerPage = 12;
const totalGroupPages = Math.ceil(groupsWithData.length / groupsPerPage);

if (!isFlat && currentPage < 1) return Astro.redirect(`/?page=1&view=groups${queryStr}`);
if (!isFlat && currentPage > totalGroupPages && totalGroupPages > 0)
    return Astro.redirect(`/?page=${totalGroupPages}&view=groups${queryStr}`);

const paginatedGroups = groupsWithData.slice((groupPage - 1) * groupsPerPage, groupPage * groupsPerPage);
const groupPaginationNumbers = Array.from({ length: totalGroupPages }, (_, i) => i + 1);

export const prerender = false;
---

<Layout>
    <ViewTabs client:load defaultView={viewParam} flatContent={null} groupsContent={null} filtersContent={null}>
        <div slot="filtersContent">
            <Filters client:load availableTags={availableTags} selectedTags={selectedTagsOptions} />
        </div>
        <div slot="flatContent">
            <ImagesList
                images={secureImages}
                currentPage={flatPage}
                totalPages={totalFlatPages}
                paginationNumbers={flatPaginationNumbers}
                baseUrl={`/?view=flat${queryStr}&page=`}
            />
        </div>
        <div slot="groupsContent">
            <GroupsList 
                groups={paginatedGroups} 
                currentPage={groupPage} 
                totalPages={totalGroupPages} 
                paginationNumbers={groupPaginationNumbers} 
                baseUrl={`/?view=groups${queryStr}&page=`}
            />
        </div>
    </ViewTabs>
</Layout>
