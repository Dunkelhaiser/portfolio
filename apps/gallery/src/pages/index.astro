---
/** biome-ignore-all lint/style/useNamingConvention: cloudinary convention */
import { v2 as cloudinary } from "cloudinary";
import { ImageDialog } from "@/components/Sections/Gallery/ImageDialog";
import ImagesGrid from "@/components/Sections/Gallery/ImagesGrid.astro";
import Pagination from "@/components/Sections/Gallery/Pagination.astro";
import Layout from "@/layouts/Layout.astro";
import type { CloudinaryImage, CloudinaryResource } from "@/lib/types";

cloudinary.config({
    cloud_name: import.meta.env.CLOUDINARY_CLOUD_NAME,
    api_key: import.meta.env.CLOUDINARY_API_KEY,
    api_secret: import.meta.env.CLOUDINARY_API_SECRET,
});

const pageParam = Astro.url.searchParams.get("page") ?? "1";
const currentPage = Number.parseInt(pageParam, 10) ?? 1;

const perPage = 9;
const searchExpression = "folder:gallery";

const maxResults = 500;

const results = await cloudinary.search
    .expression(searchExpression)
    .with_field("tags")
    .with_field("context")
    .with_field("metadata")
    .sort_by("metadata.takenAt", "desc")
    .max_results(maxResults)
    .execute();

const allImages: Omit<CloudinaryImage, "src">[] = results.resources.map((img: CloudinaryResource) => ({
    id: img.public_id,
    tags: img.tags || [],
    context: img.context || {},
    metadata: img.metadata || {},
}));

const totalImages = allImages.length;
const totalPages = Math.ceil(totalImages / perPage);

if (currentPage < 1) {
    const safeUrl = "/?page=1";
    return Astro.redirect(safeUrl);
}
if (currentPage > totalPages) {
    const safeUrl = `/?page=${totalPages}`;
    return Astro.redirect(safeUrl);
}

const startIndex = (currentPage - 1) * perPage;
const endIndex = startIndex + perPage;
const paginatedImages = allImages.slice(startIndex, endIndex);

const paginationNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);

const secureImages = paginatedImages.map((img) => {
    const secureUrl = cloudinary.url(img.id, {
        type: "authenticated",
        secure: true,
        sign_url: true,
        format: "webp",
        transformation: [
            { fetch_format: "auto", quality: "auto" },
            { flags: "keep_attribution" },
            { crop: "scale", width: 1280 },
        ],
    });

    const highResUrl = cloudinary.url(img.id, {
        type: "authenticated",
        secure: true,
        sign_url: true,
        format: "webp",
        transformation: [
            { fetch_format: "auto", quality: "auto" },
            { flags: "keep_attribution" },
            { crop: "scale", width: 1920 },
        ],
    });

    return {
        id: img.id,
        previewSrc: secureUrl,
        highResSrc: highResUrl,
        tags: img.tags,
        context: img.context,
        metadata: img.metadata,
    };
});

export const prerender = false;
---

<Layout>
    <section class="flex flex-col gap-8">
        <ImagesGrid images={secureImages} />
        <Pagination currentPage={currentPage} totalPages={totalPages} paginationNumbers={paginationNumbers} />
    </section>

    <ImageDialog client:load />

    <script>
        document.addEventListener("astro:page-load", () => {
            const triggers = document.querySelectorAll(".lightbox-trigger");
            
            triggers.forEach((trigger) => {
                trigger.addEventListener("click", (e) => {
                    if (e instanceof MouseEvent && (e.button !== 0 || e.ctrlKey || e.metaKey || e.shiftKey)) {
                        return;
                    }
                    
                    e.preventDefault(); 
                    
                    const highResSrc = trigger.getAttribute("data-highres-src");
                    
                    if (highResSrc) {
                        window.dispatchEvent(new CustomEvent("open-lightbox", { 
                            detail: { src: highResSrc } 
                        }));
                    }
                });
            });
        });
    </script>
</Layout>
